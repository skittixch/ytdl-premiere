{
  "manifest_version": 3,
  "name": "YTDL Premiere",
  "version": "0.1.0",
  "description": "Send the current tab to a local yt-dlp + ffmpeg Premiere pipeline.",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": ["http://127.0.0.1:8787/*", "http://localhost:8787/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Download for Premiere"
  }
}
