# Mount the broad root that contains your project folders.
# The extension can then send any destination folder under this root.
# Windows paths work best with forward slashes for Docker Compose.
HOST_OUTPUT_ROOT=X:/Projects

# Optional default if the extension leaves Destination folder blank.
# Full Windows paths are accepted when they are under HOST_OUTPUT_ROOT.
DEFAULT_OUTPUT_DIR=

# Premiere transcode settings.
CRF=18
PRESET=medium
AUDIO_BITRATE=192k

# Optional. Leave blank to preserve source frame rate.
# Use 24000/1001 only when you explicitly want ffmpeg to frame-drop to 23.976.
TARGET_FPS=
